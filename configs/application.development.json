{
  "$schema": "./config-schema.json",
  "app": {
    "name": "customers-service"
  },
  "health": {},
  "httpServer": {
    "type": "gin",
    "host": "127.0.0.1",
    "port": "8000",
    "development": true
  },
  "rpcServer": {
    "type": "grpc",
    "host": "127.0.0.1",
    "port": "9000"
  },
  "db": [
    {
      "name": "default",
      "host": "customers-service-db",
      "port": "5432",
      "user": "postgres",
      "password": "postgres",
      "sslmode": false,
      "dbname": "customers-service"
    }
  ],
  "logger": {
    "type": "logrus",
    "level": "debug"
  },
  "migration": [
    {
      "dbname": "default",
      "migrationdir": "db/migrations/default/"
    }
  ]
}
