{
  "$schema": "./config-schema.json",
  "appoptions": {
    "name": "customers-service"
  },
  "healthoptions": {},
  "httpserveroptions": {
    "type": "gin",
    "host": "127.0.0.1",
    "port": "8000",
    "development": true
  },
  "rpcserveroptions": {
    "host": "127.0.0.1",
    "port": "9000"
  },
  "dboptions": [
    {
      "name": "default",
      "host": "customers-service-db",
      "port": "5432",
      "user": "postgres",
      "password": "postgres",
      "sslmode": false,
      "dbname": "customers-service"
    }
  ],
  "logoptions": {
    "type": "logrus",
    "level": "debug"
  },
  "migrationoptions": [
    {
      "dbname": "default",
      "migrationdir": "db/migrations/default/"
    }
  ]
