{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frisboo-bank/services/config-schema.json",
  "title": "Service Configuration",
  "type": "object",
  "required": ["appOptions", "logOptions"],
  "properties": {
    "appOptions": {
      "type": "object",
      "$ref": "#/$defs/appOptions"
    },
    "dbOptions": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "#/$defs/dbOptions"
      }
    },
    "grpcOptions": {
      "type": "object",
      "$ref": "#/$defs/grpcOptions"
    },
    "httpOptions": {
      "type": "object",
      "$ref": "#/$defs/httpOptions"
    },
    "logOptions": {
      "type": "object",
      "$ref": "#/$defs/logOptions"
    },
    "migrationOptions": {
      "type": "array",
      "items": {
        "type": "object",
        "$ref": "#/$defs/migrationOptions"
      }
    }
  },
  "$defs": {
    "appOptions": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the service"
        }
      },
      "required": ["name"]
    },
    "dbOptions": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Internal name used to identify the database"
        },
        "host": {
          "type": "string",
          "description": "Host of the database"
        },
        "port": {
          "type": "string",
          "description": "Port of the database"
        },
        "user": {
          "type": "string",
          "description": "User of the database"
        },
        "password": {
          "type": "string",
          "description": "User password of the database"
        },
        "sslMode": {
          "type": "boolean",
          "description": "Use ssl to connect to the database"
        },
        "database": {
          "type": "string",
          "description": "Name of the database"
        }
      },
      "required": ["name", "host", "port", "dbName"]
    },
    "grpcOptions": {
      "properties": {
        "port": "string",
        "description": "Port for the GRPC server to listen to"
      }
    },
    "httpOptions": {
      "properties": {
        "port": "string",
        "description": "Port for the HTTP server to listen to"
      }
    },
    "logOptions": {
      "properties": {
        "level": ["debug", "info", "warn", "error", "panic", "fatal"],
        "type": ["logrus"]
      }
    },
    "migrationOptions": {
      "properties": {
        "dbName": {
          "type": "string",
          "description": "Name of the database to migrate"
        },
        "migrationDir": {
          "type": "string",
          "description": "Path to the migration files"
        }
      },
      "required": ["dbName", "migrationDir"]
    }
  }
}
